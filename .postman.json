            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "pm.test('Status 200', () => pm.response.to.have.status(200));",
                    "pm.test('Returns reference and a redirect URL', () => {",
                    "  const body = pm.response.json();",
                    "  pm.expect(body.success).to.be.true;",
                    "  pm.expect(body.reference).to.be.a('string');",
                    "  // Checkout.com returns redirect_url; Paystack legacy returns authorization_url",
                    "  const redirectUrl = body.redirect_url || body.authorization_url;",
                    "  pm.expect(redirectUrl, 'redirect_url or authorization_url must be present').to.be.a('string').and.not.empty;",
                    "  pm.collectionVariables.set('checkout_reference', body.reference);",
                    "});"
                  ]
                }
              }
            ]
