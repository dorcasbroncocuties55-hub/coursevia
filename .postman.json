            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "pm.test('Status 200 or 500', () => {",
                    "  pm.expect(pm.response.code).to.be.oneOf([200, 500]);",
                    "});",
                    "pm.test('Returns message', () => {",
                    "  const body = pm.response.json();",
                    "  pm.expect(body.message || body.success).to.exist;",
                    "});"
                  ]
                }
              }
            ]
          }
        ]
