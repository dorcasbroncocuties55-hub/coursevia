      {
        "name": "Checkout",
        "item": [
          {
            "name": "Initialize Checkout",
            "request": {
              "method": "POST",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "url": "{{base_url}}/api/checkout/initialize",
              "body": {
                "mode": "raw",
                "raw": "{\n  \"email\": \"{{email}}\",\n  \"user_id\": \"{{user_id}}\",\n  \"type\": \"booking\",\n  \"amount\": 50,\n  \"content_id\": \"booking-123\",\n  \"content_title\": \"Test Session\"\n}"
