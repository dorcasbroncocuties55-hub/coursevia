        "name": "Subscriptions",
        "item": [
          {
            "name": "Get Subscription Plans",
            "request": {
              "method": "GET",
              "url": "{{base_url}}/api/subscription/plans"
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "pm.test('Status 200', () => pm.response.to.have.status(200));",
                    "pm.test('Returns success with data array', () => {",
                    "  const body = pm.response.json();",
                    "  pm.expect(body.success).to.be.true;",
                    "  pm.expect(body.data).to.be.an('array').that.is.not.empty;",
                    "});"
                  ]
                }
              }
            ]
          },
          {
            "name": "Get Current Subscription",
            "request": {
              "method": "GET",
              "url": "{{base_url}}/api/subscriptions/current?user_id={{user_id}}"
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "pm.test('Status 200', () => pm.response.to.have.status(200));",
                    "pm.test('Returns success with data', () => {",
                    "  const body = pm.response.json();",
                    "  pm.expect(body.success).to.be.true;",
                    "  pm.expect(body.data).to.have.property('user_id');",
                    "});"
                  ]
                }
              }
            ]
          },
          {
            "name": "Get Current Subscription - Missing user_id",
            "request": {
              "method": "GET",
              "url": "{{base_url}}/api/subscriptions/current"
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "pm.test('Status 400 when user_id missing', () => pm.response.to.have.status(400));",
                    "pm.test('Returns error message', () => {",
                    "  const body = pm.response.json();",
                    "  pm.expect(body.message).to.include('user_id');",
                    "});"
                  ]
                }
              }
            ]
          },
          {
            "name": "Initialize Subscription",
            "request": {
              "method": "POST",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "url": "{{base_url}}/api/subscriptions/initialize",
              "body": {
                "mode": "raw",
                "raw": "{\n  \"email\": \"{{email}}\",\n  \"userId\": \"{{user_id}}\",\n  \"planId\": \"monthly\"\n}"
              }
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "pm.test('Status 200', () => pm.response.to.have.status(200));",
                    "pm.test('Returns reference and payment method signal', () => {",
                    "  const body = pm.response.json();",
                    "  pm.expect(body.success).to.be.true;",
                    "  pm.expect(body.reference).to.be.a('string');",
                    "  pm.collectionVariables.set('sub_reference', body.reference);",
                    "  // Checkout.com Frames flow: use_frames=true with amount/currency/plan",
                    "  // Legacy Paystack flow: use_frames=false with redirect_url/authorization_url",
                    "  if (body.use_frames === true) {",
                    "    pm.test('Frames flow: has amount, currency, plan', () => {",
                    "      pm.expect(body.amount).to.be.a('number');",
                    "      pm.expect(body.currency).to.be.a('string');",
                    "      pm.expect(body.plan).to.be.a('string');",
                    "    });",
                    "  } else {",
                    "    pm.test('Redirect flow: has redirect_url or authorization_url', () => {",
                    "      const redirectUrl = body.redirect_url || body.authorization_url;",
                    "      pm.expect(redirectUrl, 'redirect_url or authorization_url must be present').to.be.a('string').and.not.empty;",
                    "    });",
                    "  }",
                    "});"
                  ]
                }
              }
            ]
          },
          {
            "name": "Initialize Subscription - Invalid Plan",
            "request": {
              "method": "POST",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "url": "{{base_url}}/api/subscriptions/initialize",
              "body": {
                "mode": "raw",
                "raw": "{\n  \"email\": \"{{email}}\",\n  \"userId\": \"{{user_id}}\",\n  \"planId\": \"nonexistent\"\n}"
              }
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "pm.test('Status 400 for invalid plan', () => pm.response.to.have.status(400));",
                    "pm.test('Returns error message', () => {",
                    "  const body = pm.response.json();",
                    "  pm.expect(body.message).to.include('plan');",
                    "});"
                  ]
                }
              }
            ]
          },
          {
            "name": "Cancel Subscription",
            "request": {
              "method": "POST",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "url": "{{base_url}}/api/subscriptions/cancel",
              "body": {
                "mode": "raw",
                "raw": "{\n  \"userId\": \"{{user_id}}\"\n}"
